{
  "expo": {
    "name": "ShopNow",
    "slug": "shopnow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "shopnow",
    "splash": { "image": "./assets/splash.png", "resizeMode": "contain", "backgroundColor": "#3b82f6" },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopnow.app",
      "infoPlist": { "NSCameraUsageDescription": "Used for product image uploads" }
    },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#3b82f6" },
      "package": "com.shopnow.app"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": { "typedRoutes": true },
    "extra": {
      "API_URL": "http://localhost:8080",
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
